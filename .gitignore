__pycache__/
*.pyc
.env
node_modules/
.temp/
# Worktrees (per ADR 0008) live at <repo>/worktrees/<bd-id-or-slug>/.
# The directory + its contents are runtime-only and must never be tracked
# (a worktree is a checkout of the same repo — committing one would create
# infinite recursion). Per codex 2026-05-17 D4 review: without this entry,
# first worktree creation pollutes `git status` with thousands of untracked
# files in the main checkout.
worktrees/

.claude/worktrees/
.claude/worktree-archives/
.claude/scheduled_tasks.lock
# Legacy: pre-Fix-D1 lease location. New hook (post-2026-05-17) writes leases
# to <git-common-dir>/session-leases/ instead. Existing dev machines may still
# have orphaned lease files here; gitignore the path so they don't show up as
# untracked. Fresh clones never see this directory.
.claude/session-leases/
.superpowers/
.claude/skills/gstack/

# Codex (and any future cross-vendor adversarial review) transcripts live
# locally only — kept off the public repo per the 2026-05-17 "release-ready"
# cleanliness call. Findings should be summarized in handoff docs / PR
# bodies / pitfalls entries as appropriate; the raw transcripts are dev
# scratch space, not project artifacts.
dev/adversarial/

# Local dev scratch — grim screenshots, dev-server logs, throwaway probes.
# Validation evidence stays local; the fidelity comparison is summarized in
# handoff docs / PR bodies, not committed as artifacts.
dev/scratch/

# Winlink Express / RMS Trimode reference material — third-party Windows
# binaries audited locally during the 2026-05-17 UX brainstorm (and any
# subsequent audits). Not redistributable, not project artifacts; raw
# binaries + extracted contents stay off the public repo. Findings get
# summarized in design docs and pitfalls entries.
dev/winlink-reference/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# === Added by Tauri 2 + React + Vite scaffold (Task 1) ===
# Vite build output
dist/
dist-ssr/
*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Tauri / Rust build artifacts
src-tauri/target/
src-tauri/WixTools/
src-tauri/gen/

# Editor — share .vscode/extensions.json only (recommended-extensions list)
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.swp
*.swo
.playwright-mcp/
