{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tuxlink",
  "version": "0.53.0",
  "identifier": "com.tuxlink.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "tuxlink",
        "width": 1200,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:*; img-src 'self' data: tile:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "license": "GPL-3.0-or-later",
    "licenseFile": "../LICENSE",
    "shortDescription": "Open-source Winlink-compatible amateur-radio email client",
    "longDescription": "Tuxlink is an open-source Winlink-compatible amateur-radio email client written in Rust + React. Replaces Pat (the prior fork dependency) with a native, no-credentials-on-disk implementation. Supports HF, VHF, and UHF transports including ARDOP, VARA, and AX.25.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/wle-forms/**/*",
      "resources/propagation/ssn-forecast.json"
    ],
    "linux": {
      "deb": {
        "section": "hamradio",
        "priority": "optional",
        "depends": [
          "libsecret-1-0"
        ],
        "files": {
          "/usr/share/applications/tuxlink.desktop": "../scripts/tuxlink.desktop"
        }
      },
      "rpm": {
        "release": "1",
        "epoch": 0,
        "depends": [
          "libsecret",
          "webkit2gtk4.1",
          "libayatana-appindicator-gtk3"
        ]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
