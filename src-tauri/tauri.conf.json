{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tuxlink",
  "version": "0.0.1",
  "identifier": "com.tuxlink.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "tuxlink",
        "width": 1200,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:*; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Network",
    "shortDescription": "Open-source Winlink-compatible amateur-radio email client",
    "longDescription": "Tuxlink is an open-source Winlink-compatible amateur-radio email client written in Rust + React. Replaces Pat (the prior fork dependency) with a native, no-credentials-on-disk implementation. Supports HF, VHF, and UHF transports including ARDOP, VARA, and AX.25.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/wle-forms/**/*"],
    "linux": {
      "deb": {
        "section": "hamradio",
        "priority": "optional",
        "files": {
          "/usr/share/applications/com.tuxlink.app.desktop": "../scripts/com.tuxlink.app.desktop"
        }
      }
    }
  }
}
